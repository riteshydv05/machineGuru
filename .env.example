# ============================================================
# MachineGuru — Environment Configuration Template
# ============================================================
# Copy this file to .env and edit values for your environment:
#   cp .env.example .env
#
# Three deployment presets are documented below:
#   [DEV]     Local development (macOS/Linux)
#   [PROD]    Native production (Jetson Orin, Ubuntu ARM64)
#   [DOCKER]  Docker Compose deployment
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
PROJECT_NAME=MachineGuru
VERSION=0.2.0

# Set DEBUG=false in production — disables /docs and /redoc
# [DEV]=true  [PROD]=false  [DOCKER]=false
DEBUG=false

# ------------------------------------------------------------
# PORTS
# (change these if you have conflicts on your system)
# ------------------------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=5173

# ------------------------------------------------------------
# CORS — Allowed frontend origins
# [DEV]:    ["http://localhost:5173","http://localhost:3000"]
# [PROD]:   ["http://<jetson-ip>:5173","http://localhost:5173"]
# [DOCKER]: ["http://localhost:80","http://localhost"]
# ------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80"]

# ------------------------------------------------------------
# OLLAMA — LLM Inference Server
# [DEV]:    http://localhost:11434
# [PROD]:   http://localhost:11434   (Ollama installed natively on Jetson)
# [DOCKER]: http://ollama:11434      (Docker service name)
#
# On Jetson Orin, Ollama must be installed NATIVELY (not Docker)
# because the official Ollama Docker image does not support
# Jetson CUDA. Run: deploy/jetson_setup.sh to install Ollama.
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# LLM model name — must be pulled first with: ollama pull <model>
# Recommended for Jetson (low VRAM): llama3.2:1b or phi3:mini
LLM_MODEL=llama3.2:1b

# Vision/multimodal model (used if ENABLE_MULTIMODAL=true)
VISION_MODEL=llava:7b

# Ollama server settings
OLLAMA_NUM_PARALLEL=2
OLLAMA_KEEP_ALIVE=300s
OLLAMA_DEBUG=0

# LLM generation parameters
NUM_CTX=8192
NUM_PREDICT=4096
LLM_TEMPERATURE=0.1
LLM_KEEP_ALIVE=10m

# ------------------------------------------------------------
# EMBEDDING MODEL (SentenceTransformers, runs locally)
# Downloaded on first use from HuggingFace Hub.
# Cached in ~/.cache/huggingface/ (or HF_HOME env var)
# ------------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ------------------------------------------------------------
# QDRANT — Vector Database
# [DEV]:    host=localhost, port=6333  (native qdrant_bin)
# [PROD]:   host=localhost, port=6333  (native qdrant_bin)
# [DOCKER]: host=qdrant,    port=6333  (Docker service name)
# ------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=machine_guru
QDRANT_LOG_LEVEL=INFO

# Path where Qdrant stores its data (for native / start.sh mode)
# This is passed to the qdrant binary via QDRANT__STORAGE__STORAGE_PATH
QDRANT_STORAGE_PATH=./storage/qdrant

# ------------------------------------------------------------
# STORAGE — Runtime data directories
# Use absolute paths or paths relative to the project root.
# These directories are created automatically on startup.
# They are listed in .gitignore so data is never committed.
# ------------------------------------------------------------
UPLOAD_DIR=./storage/uploads
LOG_DIR=./logs
CACHE_DIR=./storage/cache
EMBEDDINGS_DIR=./storage/embeddings

# ------------------------------------------------------------
# DOCUMENT INGESTION
# ------------------------------------------------------------
# Maximum upload file size in bytes (default: 50 MB)
MAX_FILE_SIZE=52428800

# RAG chunk settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Number of chunks to retrieve per query
TOP_K=5

# Embedding batch size (lower for memory-constrained devices)
BATCH_SIZE=64

# Pages to process in parallel during PDF ingestion
PARALLEL_PAGES=4

# Hybrid retrieval weights (must sum to 1.0)
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7

# Minimum relevance score to include a result
SCORE_THRESHOLD=0.15

# ------------------------------------------------------------
# HARDWARE / JETSON ACCELERATION
# [DEV]:  DEVICE=cpu, USE_FP16=false
# [PROD]: DEVICE=cuda, USE_FP16=true (requires JetPack + PyTorch)
#
# To enable GPU on Jetson:
#   1. Run deploy/jetson_setup.sh first
#   2. Set DEVICE=cuda and USE_FP16=true below
#   3. Flash Attention requires Ampere+ GPU (Jetson Orin qualifies)
# ------------------------------------------------------------
DEVICE=cpu
USE_FP16=false
USE_FLASH_ATTENTION=false
QUANTIZE=dynamic
ENABLE_MULTIMODAL=true

# ------------------------------------------------------------
# MEMORY MANAGEMENT
# ------------------------------------------------------------
# Memory budget before aggressive GC is triggered (MB)
MEMORY_BUDGET_MB=2048

# Seconds before an idle model is unloaded from memory
IDLE_MODEL_TIMEOUT=300

# Concurrency limits — tune based on available RAM
MAX_CONCURRENT_LLM=2
MAX_CONCURRENT_EMBEDDING=1
MAX_CONCURRENT_QDRANT=4

# ------------------------------------------------------------
# CACHING
# ------------------------------------------------------------
ENABLE_CACHING=true

# Query result cache TTL in seconds (default: 5 minutes)
CACHE_TTL_QUERY=300

# Embedding cache TTL in seconds (default: 24 hours)
CACHE_TTL_EMBEDDING=86400

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
# Set JSON_LOGGING=true for production log aggregation
# [DEV]=false  [PROD]=true
JSON_LOGGING=false

LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
LOG_MAX_SIZE_MB=10

# ------------------------------------------------------------
# FEATURES
# ------------------------------------------------------------
ENABLE_STREAMING=true
ENABLE_BENCHMARK=true
ENABLE_REQUEST_LOGGING=true
METRICS_ENABLED=true

# HTTP request timeout in seconds
REQUEST_TIMEOUT_SECONDS=120

# ============================================================
# JETSON PRODUCTION PRESET
# ============================================================
# Uncomment these lines for Jetson Orin native deployment:
#
# DEBUG=false
# DEVICE=cuda
# USE_FP16=true
# USE_FLASH_ATTENTION=true
# JSON_LOGGING=true
# LOG_LEVEL=INFO
# MEMORY_BUDGET_MB=4096
# MAX_CONCURRENT_LLM=2
# BATCH_SIZE=32
# OLLAMA_BASE_URL=http://localhost:11434
# QDRANT_HOST=localhost
# UPLOAD_DIR=./storage/uploads
# LOG_DIR=./logs
# ============================================================
