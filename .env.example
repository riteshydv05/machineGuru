# MachineGuru Environment Configuration

# Application
PROJECT_NAME=MachineGuru
DEBUG=false
VERSION=0.1.0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.2:1b
EMBEDDING_MODEL=intfloat/multilingual-e5-small
OLLAMA_NUM_PARALLEL=2
OLLAMA_KEEP_ALIVE=300s
OLLAMA_DEBUG=0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=machine_guru
QDRANT_LOG_LEVEL=INFO

# Ingestion
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
BATCH_SIZE=64
PARALLEL_PAGES=4

# Jetson Hardware Optimizations
DEVICE=cuda
USE_FP16=true
USE_FLASH_ATTENTION=true
QUANTIZE=dynamic

# Memory Management
MEMORY_BUDGET_MB=2048
IDLE_MODEL_TIMEOUT=300

# Caching
ENABLE_CACHING=true
CACHE_TTL_QUERY=300
CACHE_TTL_EMBEDDING=86400

# Concurrency
MAX_CONCURRENT_LLM=2
MAX_CONCURRENT_EMBEDDING=1

# Logging
JSON_LOGGING=false
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
LOG_MAX_SIZE_MB=10
LOG_DIR=logs

# Features
ENABLE_STREAMING=true
ENABLE_CACHING=true
ENABLE_BENCHMARK=true
ENABLE_REQUEST_LOGGING=true
METRICS_ENABLED=true
